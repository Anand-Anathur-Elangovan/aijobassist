# ── Supabase ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Anthropic (Claude AI) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Razorpay Billing ─────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-webhook-secret

# ── App Settings ─────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Job Bot Notifications ──────────────────────
# Telegram Bot (primary — free, instant mobile alerts)
#   Setup: Open Telegram → @BotFather → /newbot → copy token
#          Then message @userinfobot → /start → copy your Id
TELEGRAM_BOT_TOKEN=8341846675:AAHLVjv-SE-Vn1tAjfL5p4VuV_d7h5ZRpQ4
# TELEGRAM_CHAT_ID is now per-user (saved in DB via Settings → Notifications)
# Each user enters their own Chat ID from @userinfobot in the dashboard

# Gmail SMTP (fallback + always sent — HTML email with full copy-paste answers)
#   Setup: Enable 2FA on Gmail → https://myaccount.google.com/apppasswords
#          Create "App Password" for "Mail" → paste below (NOT your regular Gmail password)
GMAIL_ADDRESS=you@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Where to receive email alerts (defaults to GMAIL_ADDRESS if not set)
NOTIFICATION_EMAIL=you@gmail.com
